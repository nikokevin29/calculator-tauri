{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "identifier": "com.calculator.app",
  "productName": "Calculator",
  "version": "0.1.0",
  "build": {
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Calculator",
        "width": 340,
        "height": 580,
        "resizable": false,
        "center": true,
        "decorations": true,
        "transparent": false,
        "alwaysOnTop": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi", "app", "dmg", "appimage", "deb", "rpm"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "copyright": "",
    "category": "Utility",
    "shortDescription": "Simple calculator",
    "longDescription": "Cross-platform calculator built with Tauri + Vanilla JS",
    "windows": {
      "digestAlgorithm": "sha256",
      "webviewInstallMode": { "type": "embedBootstrapper" },
      "nsis": {
        "installMode": "currentUser",
        "languages": ["English"]
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15",
      "signingIdentity": null
    },
    "linux": {
      "appimage": { "bundleMediaFramework": true }
    }
  }
}
