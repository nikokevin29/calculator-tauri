{
  "name": "calculator-tauri",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev":             "vite",
    "build":           "tsc && vite build",
    "preview":         "vite preview",
    "tauri":           "tauri",
    "tauri:dev":       "tauri dev",
    "tauri:build":     "tauri build",
    "build:win":       "tauri build --target x86_64-pc-windows-msvc",
    "build:mac-intel": "tauri build --target x86_64-apple-darwin",
    "build:mac-arm":   "tauri build --target aarch64-apple-darwin",
    "build:linux":     "tauri build --target x86_64-unknown-linux-gnu",
    "release":         "git tag v$(node -p \"require('./package.json').version\") && git push --tags"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-shell": "^2.0.0",
    "open-props": "^1.7.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0"
  }
}
